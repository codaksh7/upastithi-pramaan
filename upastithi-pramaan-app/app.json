{
  "expo": {
    "name": "Upastithi-Pramaan",
    "slug": "upastithi-pramaan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Updated-icon--2.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/Updated-icon--2.png",
      "resizeMode": "contain",
      "backgroundColor": "#020408"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.frcrce.upastithi",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera required for face recognition attendance.",
        "NSLocalNetworkUsageDescription": "Network access required for device verification.",
        "NSBluetoothAlwaysUsageDescription": "Bluetooth is required for proximity-based attendance verification.",
        "NSBluetoothPeripheralUsageDescription": "Bluetooth is required to broadcast attendance beacon."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Updated-icon--2.png",
        "backgroundColor": "#020408"
      },
      "package": "com.frcrce.upastithi",
      "permissions": [
        "CAMERA",
        "ACCESS_NETWORK_STATE",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "BLUETOOTH_ADVERTISE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Upastithi-Pramaan to use camera for face recognition."
        }
      ],
      "expo-secure-store",
      "expo-document-picker",
      "@react-native-community/datetimepicker",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow Upastithi-Pramaan to use Bluetooth for attendance proximity verification."
        }
      ],
      "./plugins/withBLE"
    ],
    "scheme": "upastithi",
    "extra": {
      "eas": {
        "projectId": "5b401684-c18b-46ae-81a7-7950cf1763b4"
      }
    },
    "owner": "babayaga296"
  }
}