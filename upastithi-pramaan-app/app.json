{
  "expo": {
    "name": "Upastithi-Pramaan",
    "slug": "upma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Updated-icon--2.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/Updated-icon--2.png",
      "resizeMode": "contain",
      "backgroundColor": "#020408"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.frcrce.upastithi",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera required for face recognition attendance.",
        "NSLocalNetworkUsageDescription": "Network access required for device verification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Updated-icon--2.png",
        "backgroundColor": "#020408"
      },
      "package": "com.frcrce.upastithi",
      "permissions": [
        "CAMERA",
        "ACCESS_NETWORK_STATE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_ADVERTISE",
        "BLUETOOTH_CONNECT",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Upastithi-Pramaan to use camera for face recognition."
        }
      ],
      "expo-secure-store",
      "expo-document-picker",
      "@react-native-community/datetimepicker",
      "react-native-ble-plx",
      "./plugins/withBleAdvertiser"
    ],
    "scheme": "upastithi",
    "extra": {
      "eas": {
        "projectId": "c7a73b99-e6d8-4abf-86bb-5b9c2b16f546"
      }
    },
    "owner": "rodriguesblaises-organizationr"
  }
}
